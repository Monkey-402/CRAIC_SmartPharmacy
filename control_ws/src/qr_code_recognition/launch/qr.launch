<launch>
  <arg name="board1_decode_service" default="/yaofang_vision/board1_decode" />
  <arg name="image_ready_timeout_sec" default="0.2" />
  <arg name="image_ready_poll_sec" default="0.01" />

  <node
      pkg="qr_code_recognition"
      type="qr_node.py"
      name="qr_node"
      output="screen">
    <param name="board1_decode_service" value="$(arg board1_decode_service)" />
    <param name="image_ready_timeout_sec" value="$(arg image_ready_timeout_sec)" />
    <param name="image_ready_poll_sec" value="$(arg image_ready_poll_sec)" />
  </node>
</launch>
