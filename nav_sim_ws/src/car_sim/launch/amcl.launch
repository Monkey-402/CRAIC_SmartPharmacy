<launch>
  <!-- AMCL自适应蒙特卡洛定位节点 -->
    <node pkg="amcl" type="amcl" name="amcl" output="screen">    <!-- 基础参数配置 -->

    <!-- 里程计模型类型："diff" 差速/阿克曼底盘 -->
    <param name="odom_model_type" value="diff"/>
    
    <!-- 里程计噪声参数（alpha1-4，diff 模型） -->
    <param name="odom_alpha1" value="0.1"/>  <!-- 旋转引起的旋转噪声 -->
    <param name="odom_alpha2" value="0.1"/>  <!-- 平移引起的旋转噪声 -->
    <param name="odom_alpha3" value="0.1"/>  <!-- 平移引起的平移噪声 -->
    <param name="odom_alpha4" value="0.1"/>  <!-- 旋转引起的平移噪声 -->
    
    <!-- 可视化参数 -->
    <param name="gui_publish_rate" value="10.0"/> <!-- RViz可视化发布频率(Hz) -->
    
    <!-- 激光雷达参数 -->
    <param name="laser_max_beams" value="30"/>    <!-- 每次处理的最大激光束数量 -->
    <param name="laser_model_type" value="likelihood_field"/> <!-- 使用似然场模型 -->
    <param name="laser_likelihood_max_dist" value="2.0"/> <!-- 似然场最大有效距离(m) -->
    
    <!-- 激光测量模型权重参数 -->
    <param name="laser_z_hit" value="0.5"/>      <!-- 正确测量的概率权重 -->
    <param name="laser_z_short" value="0.05"/>   <!-- 短距离测量的概率权重 -->
    <param name="laser_z_max" value="0.05"/>     <!-- 最大距离测量的概率权重 -->
    <param name="laser_z_rand" value="0.5"/>     <!-- 随机测量的概率权重 -->
    <param name="laser_sigma_hit" value="0.2"/>  <!-- 测量的高斯噪声标准差(m) -->
    <param name="laser_lambda_short" value="0.1"/><!-- 指数分布衰减参数 -->
    
    <!-- 粒子滤波器参数 -->
    <param name="min_particles" value="500"/>    <!-- 最小粒子数量 -->
    <param name="max_particles" value="3000"/>   <!-- 最大粒子数量 -->
    <param name="kld_err" value="0.05"/>         <!-- KLD采样误差上限 -->
    <param name="kld_z" value="0.99"/>           <!-- KLD的标准正态分位数 -->
    
    <!-- 更新触发条件 -->
    <param name="update_min_d" value="0.1"/>     <!-- 最小平移距离触发更新(m) -->
    <param name="update_min_a" value="0.1"/>     <!-- 最小旋转角度触发更新(rad) -->
    
    <!-- 坐标系设置 -->
    <!-- <remap from="odom" to="/odometry/filtered"/> 修改odom话题映射 -->
    <param name="odom_frame_id" value="odom"/>   <!-- 里程计坐标系名称 -->
    <param name="base_frame_id" value="base_link"/><!-- 添加机器人基坐标系 -->
    <param name="global_frame_id" value="map"/><!-- 添加地图坐标系 -->
    <!-- 系统参数 -->
    <param name="resample_interval" value="1"/>  <!-- 重采样间隔（迭代次数） -->
    <param name="transform_tolerance" value="0.1"/><!-- TF变换容忍时间(s) -->
    
    <!-- 恢复行为参数（设为0表示禁用） -->
    <param name="recovery_alpha_slow" value="0.0"/><!-- 慢速恢复滤波器权重 -->
    <param name="recovery_alpha_fast" value="0.0"/><!-- 快速恢复滤波器权重 -->

    <!-- <param name="initial_pose_x" value="1.74"/>
    <param name="initial_pose_y" value="1.74"/> -->
    <!-- <param name="initial_pose_a" value="0"/> -->
    <!-- <param name="initial_pose_a" value="0"/> -->

    <param name="initial_pose_x" value="1.463"/>
    <param name="initial_pose_y" value="3.840"/>
    <param name="initial_pose_a" value="-3.14"/>

  </node>
</launch>