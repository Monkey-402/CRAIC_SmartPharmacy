<launch> 
   <param name="/use_sim_time" value="true" />  <!-- 启用全局仿真时间 -->
  <!-- 启动 Gazebo 空世界 + 无人机 URDF 模型 -->
  <include file="$(find car_sim)/launch/car_urdf.launch"/>
    <!-- 运行地图服务器，并且加载设置的地图-->
    <include file="$(find car_sim)/launch/map_server.launch"/>
    
    <!-- <include file="$(find car_sim)/launch/ekf_localization.launch"/> -->

    <!-- 启动定位节点 -->
    <!-- <include file="$(find car_sim)/launch/hector.launch" /> -->
    <include file="$(find car_sim)/launch/amcl.launch" />
    <!-- 运行move_base节点（TEB局部规划） -->
    <include file="$(find car_sim)/launch/move_base.launch" />

    <!-- 发布关节状态 -->
    <!-- <node pkg="joint_state_publisher" name="joint_state_publisher" type="joint_state_publisher" /> -->

    <!-- 发布机器人坐标系关系（TF 树） -->
    <!-- <node pkg="robot_state_publisher" name="robot_state_publisher" type="robot_state_publisher" /> -->

    <!-- 运行rviz -->
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find car_sim)/rviz/nav.rviz" />

    </launch>
