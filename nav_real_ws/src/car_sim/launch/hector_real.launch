<launch>
    
    <node pkg="hector_imu_attitude_to_tf" type="imu_attitude_to_tf_node" name="imu_attitude_to_tf_node" output="screen">
        <remap from="imu_topic" to="/imu" />
        <param name="base_stabilized_frame" type="string" value="base_stabilized" />
        <param name="base_frame" type="string" value="base_link" />
    </node>
<!-- 启动 Hector SLAM 算法的建图节点 -->
    <node pkg="hector_mapping" type="hector_mapping" name="hector_mapping" output="screen">
        <!-- 
            坐标系设置部分 
        -->
        <!-- 发布地图到里程计的变换 -->
        <param name="pub_map_odom_transform" value="true"/>
        <!-- 地图坐标系名称 -->
        <param name="map_frame" value="map" />
        <!-- 机器人基坐标系名称 -->
        <param name="base_frame" value="base_link" />
        <!-- 里程计坐标系名称，这里设置为与base_link相同，表示不使用外部里程计 -->
        <param name="odom_frame" value="base_link" />

        <!-- 
            TF 变换使用设置 
        -->
        <!-- 使用TF获取激光扫描数据的坐标系变换 -->
        <param name="use_tf_scan_transformation" value="true"/>
        <!-- 不使用TF提供初始位姿估计 -->
        <param name="use_tf_pose_start_estimate" value="false"/>

        <!-- 
            地图参数设置 
        -->
        <!-- 地图分辨率，单位：米/像素 -->
        <param name="map_resolution" value="0.05"/>
        <!-- 地图尺寸，单位：像素 -->
        <param name="map_size" value="2048"/>
        <!-- 地图起始点X坐标（相对于地图中心） -->
        <param name="map_start_x" value="0.5"/>
        <!-- 地图起始点Y坐标（相对于地图中心） -->
        <param name="map_start_y" value="0.5" />
        <!-- 激光数据的Z轴最小值，用于过滤无效点 -->
        <param name="laser_z_min_value" value = "-1.0" />
        <!-- 激光数据的Z轴最大值，用于过滤无效点 -->
        <param name="laser_z_max_value" value = "1.0" />
        <!-- 多分辨率地图的层级数 -->
        <param name="map_multi_res_levels" value="2" />

        <!-- 
            发布和数据处理设置 
        -->
        <!-- 地图发布周期，单位：秒 -->
        <param name="map_pub_period" value="1" />
        <!-- 激光最小有效距离，单位：米 -->
        <param name="laser_min_dist" value="0" />
        <!-- 激光最大有效距离，单位：米 -->
        <param name="laser_max_dist" value="15" />
        <!-- 是否输出计时信息 -->
        <param name="output_timing" value="false" />
        <!-- 发布地图到扫描匹配的变换 -->
        <param name="pub_map_scanmatch_transform" value="true" />
        <!-- 扫描匹配变换的坐标系名称（注释掉了） -->
        <!--<param name="tf_map_scanmatch_transform_frame_name" value="scanmatcher_frame" />-->

        <!-- 
            地图更新参数 
        -->
        <!-- 空闲区域的更新因子 -->
        <param name="update_factor_free" value="0.4"/>
        <!-- 占用区域的更新因子 -->    
        <param name="update_factor_occupied" value="0.7" />    
        <!-- 地图更新的距离阈值，单位：米 -->
        <param name="map_update_distance_thresh" value="0.05"/>
        <!-- 地图更新的角度阈值，单位：弧度 -->
        <param name="map_update_angle_thresh" value="0.001" />

        <!-- 
            服务与订阅设置 
        -->
        <!-- 是否发布地图服务 -->
        <param name="advertise_map_service" value="true"/>
        <!-- 激光扫描数据订阅队列大小 -->
        <param name="scan_subscriber_queue_size" value="5"/>
        <!-- 订阅的激光扫描话题名称 -->
        <param name="scan_topic" value="scan"/>
    </node>

    <!-- 发布静态TF：laser -> base_link -->
    <node pkg="tf" type="static_transform_publisher" name="base_to_laser_broadcaster" args="0 0 0.1 0 0 0 /base_link /laser 50"/>
    <!-- node pkg="tf" type="static_transform_publisher" name="base_to_laser_broadcaster" args="0 0 0.1 -1.5707963 0 0 /base_stabilized /laser_link 50"/ -->
    <node pkg="tf" type="static_transform_publisher" name="map_to_odom_broadcaster" args="0 0 0 0 0 0 /map /odom 50"/>

      <!-- 启动激光雷达驱动 -->
    <include file="$(find lslidar_driver)/launch/lslidar_serial.launch" />


    <!-- <node pkg="hector_to_serial" type="hector_to_serial_node" name="hector_to_serial" output="screen">
        <param name="port" value="/dev/ttyUSB0" />
        <param name="baudrate" value="9600" />
    </node> -->

    <node pkg="my_minimal_nodes" type="my_minimal_nodes_node" name="my_minimal_nodes_node" output="screen">
    </node>
</launch>